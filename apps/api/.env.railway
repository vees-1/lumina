# Railway environment variable template
# Set these in the Railway dashboard under your service → Variables
# DO NOT commit real values — this file is for reference only.

# Required: Anthropic API key for the agent route (api/routes/agent.py)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Path to the SQLite database.
# Default behaviour searches for data/orpha.sqlite relative to the working dir.
# Override with a sqlite:/// URL if you mount the DB at a custom path.
DATABASE_URL=sqlite:///data/orpha.sqlite

# Optional: allow your production frontend origin in CORS
# (localhost:3000 and *.vercel.app are already whitelisted in main.py)
# FRONTEND_ORIGIN=https://your-app.vercel.app
